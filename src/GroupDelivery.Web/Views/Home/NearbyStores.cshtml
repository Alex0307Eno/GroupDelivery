@{
    ViewData["Title"] = "揪IN｜附近揪團";
}

<style>
    body {
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
    }

    .page-title {
        font-size: 1.9rem;
        font-weight: 900;
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 900;
        margin-bottom: .2rem;
    }

    .section-sub {
        font-size: .9rem;
        color: #6b7280;
        margin-bottom: 1.2rem;
    }

    .store-card {
        border-radius: 1.4rem;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 14px 40px rgba(15,23,42,.08);
        transition: .25s;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

        .store-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 28px 60px rgba(15,23,42,.18);
        }

        .store-card.closed {
            opacity: .6;
        }

        .store-card.urgent {
            outline: 2px solid rgba(239,68,68,.6);
        }

    .store-cover {
        height: 150px;
        background-size: cover;
        background-position: center;
        background-color: #e5e7eb;
    }

    .store-body {
        padding: 1.2rem 1.4rem 1.4rem;
        flex: 1;
    }

    .store-name {
        font-weight: 800;
        font-size: 1.05rem;
    }

    .store-meta {
        font-size: .8rem;
        color: #6b7280;
    }

    .store-hours {
        font-size: .8rem;
    }

    .toolbar-box {
        background: #ffffff;
        border-radius: 1rem;
        padding: 1rem;
        box-shadow: 0 10px 30px rgba(15,23,42,.06);
    }

    .location-tip {
        font-size: .85rem;
        color: #6b7280;
    }

    .btn.disabled {
        pointer-events: none;
        opacity: .6;
    }
</style>

<div id="app" class="container py-5">

    <div class="mb-4">
        <div class="page-title">附近正在揪的店</div>
        <div class="text-muted small">
            上面是正在開團的店，下方是還沒有人動手開團的店。
        </div>
    </div>

    <div class="toolbar-box mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-lg-4 col-md-6">
                <label class="form-label fw-bold">搜尋</label>
                <input type="text"
                       class="form-control"
                       placeholder="搜尋店家名稱、地址、餐點..."
                       v-model="searchText">
            </div>

            <div class="col-lg-3 col-md-6">
                <label class="form-label fw-bold">縣市</label>
                <select class="form-select" v-model="selectedCity" @@change="reloadStores">
                    <option value="">全部縣市</option>
                    <option v-for="city in cities" :key="city" :value="city">
                        {{ city }}
                    </option>
                </select>
            </div>

            <div class="col-lg-3 col-md-6">
                <label class="form-label fw-bold">營業狀態</label>
                <div>
                    <button class="btn btn-sm"
                            :class="filterMode === 'all' ? 'btn-dark' : 'btn-outline-dark'"
                            @@click="filterMode = 'all'">
                        全部店家
                    </button>

                    <button class="btn btn-sm ms-2"
                            :class="filterMode === 'open' ? 'btn-dark' : 'btn-outline-dark'"
                            @@click="filterMode = 'open'">
                        只看營業中
                    </button>
                </div>
            </div>

            <div class="col-lg-2 col-md-6">
                <button class="btn btn-outline-primary w-100" @@click="detectLocation">
                    重新定位
                </button>
            </div>
        </div>

        <div class="mt-3 location-tip">
            <span v-if="locationLoaded">
                已取得定位
                <span v-if="userLat && userLng">
                    （{{ userLat.toFixed(6) }}, {{ userLng.toFixed(6) }}）
                </span>
            </span>
            <span v-else>
                尚未取得定位，將以系統預設資料顯示
            </span>
        </div>
    </div>

    <div class="mb-5">
        <div class="section-title">正在開團</div>
        <div class="section-sub">越接近截止越排前面</div>

        <div v-if="activeStores.length === 0" class="text-muted small">
            目前沒有正在開團的店家
        </div>

        <div class="row g-4">
            <div class="col-lg-4 col-md-6"
                 v-for="s in activeStores"
                 :key="s.storeId">

                <div class="store-card"
                     :class="{ urgent: s.isUrgent, closed: !s.isOpenNow }">

                    <div class="store-cover"
                         :style="{ backgroundImage: 'url(' + (s.coverImageUrl || '/images/store-placeholder.jpg') + ')' }">
                    </div>

                    <div class="store-body">
                        <div class="store-hours mb-2">
                            <span v-if="s.isOpenNow" class="text-success fw-bold">
                                營業中
                            </span>
                            <span v-else class="text-danger fw-bold">
                                已打烊
                            </span>
                            <span class="text-muted ms-2">
                                {{ s.businessHours || '尚未提供營業時間' }}
                            </span>
                        </div>

                        <div class="store-name">{{ s.storeName }}</div>

                        <div class="store-meta">
                            {{ s.address || '未提供地址' }}
                            <span v-if="s.distanceText"> · {{ s.distanceText }}</span>
                        </div>

                        <div v-if="s.isUrgent"
                             class="text-danger fw-bold small mt-1">
                            剩 {{ s.minutesLeft }} 分鐘截止
                        </div>

                        <a :href="'/Store/StoreGroups?storeId=' + s.storeId"
                           class="btn btn-success w-100 mt-3">
                            查看正在開團
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div>
        <div class="section-title">尚未開團</div>
        <div class="section-sub">你可以成為發起人</div>

        <div v-if="idleStores.length === 0" class="text-muted small">
            目前沒有符合條件的店家
        </div>

        <div class="row g-4">
            <div class="col-lg-4 col-md-6"
                 v-for="s in idleStores"
                 :key="s.storeId">

                <div class="store-card"
                     :class="{ closed: !s.isOpenNow }">

                    <div class="store-cover"
                         :style="{ backgroundImage: 'url(' + (s.coverImageUrl || '/images/store-placeholder.jpg') + ')' }">
                    </div>

                    <div class="store-body">
                        <div class="store-hours mb-2">
                            <span v-if="s.isOpenNow" class="text-success fw-bold">
                                營業中
                            </span>
                            <span v-else class="text-danger fw-bold">
                                已打烊
                            </span>
                            <span class="text-muted ms-2">
                                {{ s.businessHours || '尚未提供營業時間' }}
                            </span>
                        </div>

                        <div class="store-name">{{ s.storeName }}</div>

                        <div class="store-meta">
                            {{ s.address || '未提供地址' }}
                            <span v-if="s.distanceText"> · {{ s.distanceText }}</span>
                        </div>

                        <a v-if="s.isOpenNow"
                           :href="'/Group/Create?storeId=' + s.storeId"
                           class="btn btn-outline-secondary w-100 mt-3">
                            幫這間店開一團
                        </a>

                        <button v-else
                                class="btn btn-secondary w-100 mt-3"
                                disabled>
                            已打烊，無法開團
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>
    const { createApp } = Vue;

    createApp({
        data() {
            return {
                stores: [],
                filterMode: 'all',
                searchText: '',
                selectedCity: '',
                userLat: null,
                userLng: null,
                locationLoaded: false,
                cities: [
                    '台北市',
                    '新北市',
                    '桃園市',
                    '新竹市',
                    '新竹縣',
                    '台中市',
                    '彰化縣',
                    '南投縣',
                    '雲林縣',
                    '嘉義市',
                    '嘉義縣',
                    '台南市',
                    '高雄市',
                    '屏東縣',
                    '宜蘭縣',
                    '花蓮縣',
                    '台東縣',
                    '基隆市'
                ]
            };
        },

        computed: {
            activeStores() {
                return this.stores
                    .filter(function (s) { return s.hasActiveGroup; })
                    .filter(this.filterByOpenMode)
                    .filter(this.matchSearch)
                    .sort(function (a, b) {
                        return a.minutesLeft - b.minutesLeft;
                    });
            },

            idleStores() {
                return this.stores
                    .filter(function (s) { return !s.hasActiveGroup; })
                    .filter(this.filterByOpenMode)
                    .filter(this.matchSearch)
                    .sort(function (a, b) {
                        return a.distanceValue - b.distanceValue;
                    });
            }
        },

        methods: {
            filterByOpenMode(store) {
                return this.filterMode === 'all' || store.isOpenNow;
            },

            formatDistance(distanceInMeters) {
                if (distanceInMeters === null || distanceInMeters === undefined) {
                    return '';
                }

                if (distanceInMeters < 1000) {
                    return Math.round(distanceInMeters) + ' 公尺';
                }

                return (distanceInMeters / 1000).toFixed(1) + ' 公里';
            },

            enrichStore(store) {
                store.isOpenNow = store.isOpenNow === true;
                store.hasActiveGroup = store.hasActiveGroup === true;

                if (store.distance === null || store.distance === undefined) {
                    store.distanceValue = 999999;
                    store.distanceText = '';
                } else {
                    store.distanceValue = Number(store.distance);
                    store.distanceText = this.formatDistance(store.distanceValue);
                }

                if (!store.hasActiveGroup) {
                    store.isUrgent = false;
                    store.minutesLeft = 9999;
                    return store;
                }

                try {
                    var now = new Date();
                    var deadline = store.activeGroupDeadline
                        ? new Date(store.activeGroupDeadline)
                        : null;

                    var minutesLeft = 9999;

                    if (deadline && !isNaN(deadline.getTime())) {
                        minutesLeft = Math.floor((deadline - now) / 60000);
                    }

                    store.minutesLeft = Math.max(minutesLeft, 0);
                    store.isUrgent = minutesLeft > 0 && minutesLeft <= 15;
                } catch (e) {
                    store.isUrgent = false;
                    store.minutesLeft = 9999;
                }

                return store;
            },

            fetchStores(lat, lng) {
                var vm = this;

                axios.get('/api/stores/nearby', {
                    params: {
                        lat: lat,
                        lng: lng,
                        city: vm.selectedCity
                    }
                }).then(function (res) {
                    var list = res.data || [];
                    vm.stores = list.map(function (s) {
                        return vm.enrichStore(s);
                    });
                }).catch(function (err) {
                    console.error(err);
                    vm.stores = [];
                });
            },

            reloadStores() {
                this.fetchStores(this.userLat, this.userLng);
            },

            detectLocation() {
                var vm = this;

                if (!navigator.geolocation) {
                    vm.locationLoaded = false;
                    vm.fetchStores(null, null);
                    return;
                }

                navigator.geolocation.getCurrentPosition(
                    function (position) {
                        vm.userLat = position.coords.latitude;
                        vm.userLng = position.coords.longitude;
                        vm.locationLoaded = true;
                        vm.fetchStores(vm.userLat, vm.userLng);
                    },
                    function () {
                        vm.userLat = null;
                        vm.userLng = null;
                        vm.locationLoaded = false;
                        vm.fetchStores(null, null);
                    },
                    {
                        enableHighAccuracy: true,
                        timeout: 8000,
                        maximumAge: 300000
                    }
                );
            },

            matchSearch(store) {
                if (!this.searchText) {
                    return true;
                }

                var keyword = this.searchText.toLowerCase();

                if (store.storeName &&
                    store.storeName.toLowerCase().indexOf(keyword) > -1) {
                    return true;
                }

                if (store.address &&
                    store.address.toLowerCase().indexOf(keyword) > -1) {
                    return true;
                }

                if (store.menuItems && store.menuItems.length > 0) {
                    for (var i = 0; i < store.menuItems.length; i++) {
                        var item = store.menuItems[i];
                        if (item.name &&
                            item.name.toLowerCase().indexOf(keyword) > -1) {
                            return true;
                        }
                    }
                }

                return false;
            }
        },

        mounted() {
            this.detectLocation();
        }
    }).mount('#app');
</script>