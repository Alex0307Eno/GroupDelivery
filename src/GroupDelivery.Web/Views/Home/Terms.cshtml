@{
    ViewData["Title"] = "服務條款";
}

<style>

    .terms-hero {
        background: linear-gradient(135deg,#111827,#1f2937);
        color: white;
        padding: 60px 20px;
        border-radius: 20px;
        text-align: center;
        margin-bottom: 40px;
    }

        .terms-hero h1 {
            font-size: 36px;
            font-weight: 900;
        }

    .terms-card {
        background: white;
        border-radius: 18px;
        padding: 26px;
        margin-bottom: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,.05);
    }

        .terms-card h3 {
            font-weight: 800;
            margin-bottom: 10px;
        }

    .terms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
        gap: 20px;
    }

    .terms-note {
        font-size: 14px;
        color: #64748b;
    }

</style>

<div class="container py-5" style="max-width:1000px">

    <div class="terms-hero">

        <h1>服務條款</h1>

        <p>
            使用揪IN平台前，請先閱讀以下條款
        </p>

    </div>


    <div class="terms-grid">

        <div class="terms-card">

            <h3>🍜 平台服務</h3>

            <p>
                揪IN是一個揪團訂餐平台，
                提供使用者建立或加入附近的揪團訂餐。
            </p>

            <p class="terms-note">
                平台本身不直接販售餐點，
                餐點由各合作商家提供。
            </p>

        </div>


        <div class="terms-card">

            <h3>🧾 訂單規則</h3>

            <ul>

                <li>使用者可加入揪團並選擇餐點</li>

                <li>訂單成立後將送至商家處理</li>

                <li>實際餐點內容以商家確認為準</li>

            </ul>

        </div>


        <div class="terms-card">

            <h3>💳 付款與退款</h3>

            <ul>

                <li>付款流程可能透過第三方金流服務</li>

                <li>若揪團未成立，訂單可能取消</li>

                <li>退款依金流服務流程處理</li>

            </ul>

        </div>


        <div class="terms-card">

            <h3>⚠️ 使用責任</h3>

            <p>
                使用者需確保提供的資訊正確，
                並遵守平台使用規則。
            </p>

            <p class="terms-note">
                平台保留終止違規帳號之權利。
            </p>

        </div>


        <div class="terms-card">

            <h3>📦 商家責任</h3>

            <p>
                餐點品質、製作與配送
                由各合作商家負責。
            </p>

            <p class="terms-note">
                平台主要提供訂單媒合服務。
            </p>

        </div>


        <div class="terms-card">

            <h3>📅 條款更新</h3>

            <p>
                平台可能因服務調整更新條款，
                更新內容將公布於本頁。
            </p>

        </div>

    </div>

</div>