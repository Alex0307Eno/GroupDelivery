@{
    ViewData["Title"] = "聯絡我們";
}

<style>

    .contact-hero {
        background: linear-gradient(135deg,#22c55e,#16a34a);
        color: white;
        padding: 60px 20px;
        border-radius: 20px;
        text-align: center;
        margin-bottom: 40px;
    }

        .contact-hero h1 {
            font-size: 34px;
            font-weight: 900;
        }

    .contact-card {
        background: white;
        border-radius: 18px;
        padding: 26px;
        box-shadow: 0 10px 25px rgba(0,0,0,.06);
        margin-bottom: 20px;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 20px;
    }

    .contact-btn {
        border-radius: 999px;
        padding: 12px 20px;
        font-weight: 700;
    }

    .contact-icon {
        font-size: 28px;
    }

</style>


<div class="container py-5" style="max-width:1000px">

    <div class="contact-hero">

        <h1>聯絡我們</h1>

        <p class="mt-3">
            有問題、建議、合作機會，都可以找我們
        </p>

    </div>


    <div class="contact-grid">

        <div class="contact-card text-center">

            <div class="contact-icon mb-3">
                📧
            </div>

            <h5 class="fw-bold mb-2">
                Email 客服
            </h5>

            <p class="text-muted">
                點擊即可寄送郵件
            </p>

            <a href="mailto:a0972299435@gmail.com?subject=揪IN客服"
               class="btn btn-dark contact-btn">
                寄信給我們
            </a>

        </div>


        <div class="contact-card text-center">

            <div class="contact-icon mb-3">
                💬
            </div>

            <h5 class="fw-bold mb-2">
                LINE 客服
            </h5>

            <p class="text-muted">
                加入 LINE 好友快速詢問
            </p>

            <a href="https://line.me/R/ti/p/@@558sbxwh">
                <img src="https://scdn.line-apps.com/n/line_add_friends/btn/zh-Hant.png">
            </a>

        </div>


        <div class="contact-card text-center">

            <div class="contact-icon mb-3">
                🕒
            </div>

            <h5 class="fw-bold mb-2">
                客服時間
            </h5>

            <p class="text-muted">
                週一至週五
                10:00 - 18:00
            </p>

        </div>

    </div>

</div>