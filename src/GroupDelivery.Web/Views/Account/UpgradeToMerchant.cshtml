@{
    ViewData["Title"] = "我要開店";
}

<style>

    body {
        background: #f8fafc;
    }

    .page {
        max-width: 1100px;
        margin: auto;
        padding: 4rem 1rem;
    }

    /* hero */

    .hero {
        text-align: center;
        margin-bottom: 3rem;
    }

        .hero h1 {
            font-size: 2.4rem;
            font-weight: 900;
            color: #111827;
        }

        .hero p {
            margin-top: .6rem;
            color: #6b7280;
        }

    /* grid */

    .pricing {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 22px;
    }

    /* card */

    .plan {
        background: #fff;
        border-radius: 18px;
        padding: 2rem 1.6rem;
        border: 1px solid #e5e7eb;
        transition: .25s;
        cursor: pointer;
    }

        .plan:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 40px rgba(0,0,0,.06);
        }

        .plan.active {
            border: 2px solid #f59e0b;
        }

        /* recommended */

        .plan.recommend {
            border: 2px solid #16a34a;
            transform: scale(1.05);
        }

    .badge {
        display: inline-block;
        font-size: .75rem;
        background: #16a34a;
        color: #fff;
        padding: 3px 10px;
        border-radius: 999px;
        margin-bottom: 10px;
    }

    /* text */

    .plan-name {
        font-weight: 800;
        font-size: 1.2rem;
    }

    /* price */

    .price-wrap {
        margin: 10px 0;
    }

    .origin {
        text-decoration: line-through;
        color: #9ca3af;
        font-size: .9rem;
    }

    .price {
        font-size: 2rem;
        font-weight: 900;
    }

        .price span {
            font-size: .8rem;
            color: #6b7280;
        }

    .discount {
        color: #ef4444;
        font-size: .85rem;
        font-weight: 700;
    }

    .trial {
        margin-top: 6px;
        font-size: .8rem;
        color: #16a34a;
        font-weight: 700;
    }

    /* feature */

    .feature {
        list-style: none;
        padding-left: 0;
        margin-top: 10px;
    }

        .feature li {
            margin-bottom: 6px;
            color: #374151;
            font-size: .92rem;
        }

    /* CTA */

    .cta {
        margin-top: 3rem;
        text-align: center;
    }

    .btn-start {
        background: #111827;
        color: #fff;
        border: none;
        border-radius: 999px;
        padding: 14px 26px;
        font-weight: 800;
        font-size: 1rem;
        transition: .2s;
    }

        .btn-start:hover {
            background: #000;
        }

        .btn-start:disabled {
            opacity: .5;
        }

</style>

<div id="app" class="page">

    <div class="hero">

        <h1>開始你的店家揪團</h1>

        <p>
            免費試用 30 天，讓附近客人一起揪團向你下單
        </p>

    </div>

    <div class="pricing">

        <div v-for="p in plans"
             :key="p.id"
             class="plan"
             :class="{active:selectedPlan===p.id,recommend:p.recommend}"
             v-on:click="select(p.id)">

            <div v-if="p.recommend" class="badge">
                最多商家選擇
            </div>

            <div class="plan-name">
                {{p.name}}
            </div>

            <div class="price-wrap">

                <div class="origin">
                    ${{p.original}}
                </div>

                <div class="price">
                    ${{p.price}} <span>/月</span>
                </div>

                <div class="discount">
                    -{{discount(p)}}% 折扣
                </div>

            </div>

            <div class="trial">
                免費試用 30 天
            </div>

            <ul class="feature">
                <li v-for="f in p.features">{{f}}</li>
            </ul>

        </div>

    </div>

    <div class="cta">

        <button class="btn-start"
                :disabled="!selectedPlan"
                v-on:click="next">

            下一步：填店家資料

        </button>

    </div>

</div>

@section Scripts {

    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>

    <script>

        const {createApp}=Vue;

        createApp({

        data(){

        return{

        selectedPlan:null,

        plans:[

        {
        id:"299",
        name:"入門方案",
        original:499,
        price:299,
        features:[
        "電子菜單",
        "揪團開單",
        "訂單管理"
        ]
        },

        {
        id:"499",
        name:"成長方案",
        original:699,
        price:499,
        features:[
        "電子菜單可使用圖片",
        "入門全部功能",
        "店家頁展示"
        ]
        },

        {
        id:"699",
        name:"專業方案",
        original:999,
        price:699,
        features:[
        "客製化訂單",
        "499全部功能",
        "進階訂單管理"
        ]
        },

        {
        id:"999",
        name:"推薦方案",
        original:1299,
        price:999,
        recommend:true,
        features:[
        "商家推薦曝光",
        "699全部功能",
        "更多流量導入"
        ]
        }

        ]

        };

        },

        methods:{

        select(plan){

        this.selectedPlan=plan;

        },

        discount(plan){

        return Math.round(
        (1-plan.price/plan.original)*100
        );

        },

        next(){

        window.location="/Account/UpgradeToMerchantForm?plan="+this.selectedPlan;

        }

        }

        }).mount("#app");

    </script>

}