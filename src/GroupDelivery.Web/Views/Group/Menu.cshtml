@{
    ViewData["Title"] = "揪IN｜選餐加入";
    var groupId = ViewData["GroupPublicId"]?.ToString() ?? "";
}

<style>
    body {
        background: radial-gradient(circle at top left, rgba(34,197,94,.10), transparent 26%), radial-gradient(circle at top right, rgba(59,130,246,.10), transparent 22%), linear-gradient(180deg, #f8fbff 0%, #f3f6fb 100%);
        min-height: 100vh;
    }

    .menu-page {
        max-width: 1080px;
        margin: 0 auto;
    }

    .hero-card {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 28px;
        min-height: 220px;
        margin-bottom: 24px;
        background: linear-gradient(135deg, rgba(17,24,39,.82), rgba(31,41,55,.72)), linear-gradient(135deg, #16a34a, #22c55e);
        color: #fff;
        box-shadow: 0 24px 60px rgba(15, 23, 42, .16);
    }

        .hero-card::before {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            right: -70px;
            top: -80px;
            border-radius: 50%;
            background: rgba(255,255,255,.10);
        }

        .hero-card::after {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            left: -40px;
            bottom: -90px;
            border-radius: 50%;
            background: rgba(255,255,255,.08);
        }

    .hero-content {
        position: relative;
        z-index: 1;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 16px;
        backdrop-filter: blur(6px);
    }

    .hero-title {
        font-size: 34px;
        font-weight: 900;
        letter-spacing: -.02em;
        margin-bottom: 8px;
        line-height: 1.15;
    }

    .hero-sub {
        color: rgba(255,255,255,.88);
        font-size: 15px;
        margin-bottom: 18px;
    }

    .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .hero-meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.12);
        font-size: 13px;
        color: #fff;
    }

    .menu-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 24px;
        align-items: start;
    }

    .left-column {
        min-width: 0;
    }

    .right-column {
        min-width: 0;
    }

    .section-card {
        background: rgba(255,255,255,.82);
        border: 1px solid rgba(255,255,255,.7);
        backdrop-filter: blur(8px);
        border-radius: 24px;
        padding: 18px;
        box-shadow: 0 14px 32px rgba(15,23,42,.06);
        margin-bottom: 18px;
    }

    .category-nav {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: none;
    }

        .category-nav::-webkit-scrollbar {
            display: none;
        }

    .category-chip {
        white-space: nowrap;
        border: 1px solid #dbe4ee;
        background: #fff;
        color: #334155;
        border-radius: 999px;
        padding: 10px 16px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s ease;
    }

        .category-chip:hover {
            transform: translateY(-1px);
            border-color: #86efac;
        }

        .category-chip.active {
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: #fff;
            border-color: transparent;
            box-shadow: 0 12px 24px rgba(34,197,94,.24);
        }

    .category-section {
        margin-bottom: 28px;
        scroll-margin-top: 100px;
    }

    .category-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin: 0 0 14px;
    }

    .category-title-text {
        font-size: 22px;
        font-weight: 900;
        color: #0f172a;
        letter-spacing: -.02em;
    }

    .category-title-count {
        font-size: 13px;
        color: #64748b;
        background: #f1f5f9;
        border-radius: 999px;
        padding: 6px 10px;
        font-weight: 700;
    }

    .menu-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .menu-item-card {
        position: relative;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 14px 28px rgba(15,23,42,.06);
        transition: transform .24s ease, box-shadow .24s ease;
        min-height: 100%;
    }

        .menu-item-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 22px 40px rgba(15,23,42,.12);
        }

    .menu-media {
        position: relative;
        height: 180px;
        background: linear-gradient(135deg, #d9f99d, #bfdbfe);
        overflow: hidden;
    }

    .menu-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .menu-img-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 42px;
        color: rgba(15,23,42,.38);
        background: linear-gradient(135deg, rgba(34,197,94,.16), rgba(59,130,246,.16));
    }

    .menu-body {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 16px;
    }

    .menu-top {
        flex: 1;
    }

    .menu-name {
        font-weight: 900;
        font-size: 17px;
        line-height: 1.35;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .menu-desc {
        font-size: 13px;
        color: #64748b;
        line-height: 1.6;
        min-height: 40px;
        margin-bottom: 10px;
    }

    .menu-price-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
    }

    .menu-price {
        font-size: 22px;
        font-weight: 900;
        color: #16a34a;
        letter-spacing: -.02em;
    }

    .customize-btn {
        border: 1px solid #c7d2fe;
        background: #eef2ff;
        color: #3730a3;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 12px;
        font-weight: 800;
        transition: .2s ease;
    }

        .customize-btn:hover {
            background: #e0e7ff;
            transform: translateY(-1px);
        }

    .selected-options {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        min-height: 28px;
        margin-bottom: 14px;
    }

    .badge-option {
        background: linear-gradient(135deg, #eff6ff, #eef2ff);
        color: #1d4ed8;
        font-size: 11px;
        border-radius: 999px;
        padding: 5px 10px;
        font-weight: 700;
        border: 1px solid #dbeafe;
    }

    .qty-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-top: auto;
    }

    .qty-hint {
        font-size: 12px;
        color: #94a3b8;
        font-weight: 700;
    }

    .qty-box {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    .qty-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: none;
        background: #fff;
        font-size: 18px;
        font-weight: 900;
        color: #0f172a;
        box-shadow: 0 4px 10px rgba(15,23,42,.08);
        transition: .2s ease;
    }

        .qty-btn:hover {
            transform: scale(1.06);
            background: #f0fdf4;
            color: #15803d;
        }

    .qty-input {
        width: 42px;
        text-align: center;
        border: none;
        background: transparent;
        font-weight: 900;
        color: #0f172a;
    }

        .qty-input:focus {
            outline: none;
        }

    .summary-card {
        position: sticky;
        top: 18px;
    }

    .summary-title {
        font-size: 20px;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .summary-sub {
        color: #64748b;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .summary-total-box {
        border-radius: 20px;
        padding: 18px;
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: #fff;
        margin-bottom: 16px;
        box-shadow: 0 18px 34px rgba(15,23,42,.20);
    }

    .summary-total-label {
        font-size: 13px;
        opacity: .8;
        margin-bottom: 6px;
    }

    .summary-total-amount {
        font-size: 34px;
        font-weight: 900;
        letter-spacing: -.03em;
    }

    .summary-note-label {
        font-size: 14px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .note-textarea {
        width: 100%;
        min-height: 120px;
        border-radius: 18px;
        border: 1px solid #dbe4ee;
        padding: 14px 14px;
        font-size: 14px;
        resize: vertical;
        transition: .2s ease;
        background: #fff;
    }

        .note-textarea:focus {
            outline: none;
            border-color: #86efac;
            box-shadow: 0 0 0 4px rgba(34,197,94,.10);
        }

    .note-hint {
        font-size: 12px;
        color: #64748b;
        line-height: 1.7;
        margin-top: 8px;
    }

    .summary-divider {
        height: 1px;
        background: #e5e7eb;
        margin: 16px 0;
    }

    .selected-count {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
        color: #334155;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .checkout-btn {
        width: 100%;
        border: none;
        border-radius: 999px;
        padding: 15px 20px;
        font-size: 16px;
        font-weight: 900;
        color: white;
        background: linear-gradient(135deg, #16a34a, #22c55e);
        box-shadow: 0 16px 30px rgba(34,197,94,.24);
        transition: .2s ease;
    }

        .checkout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 36px rgba(34,197,94,.30);
        }

        .checkout-btn:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

    .summary-safe-text {
        text-align: center;
        font-size: 12px;
        color: #64748b;
        margin-top: 10px;
        line-height: 1.7;
    }

    .empty-box {
        text-align: center;
        padding: 60px 20px;
        border-radius: 24px;
        background: rgba(255,255,255,.82);
        box-shadow: 0 14px 32px rgba(15,23,42,.06);
        color: #64748b;
    }

    .modal-content {
        border: none;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 24px 50px rgba(15,23,42,.18);
    }

    .modal-header {
        border-bottom: 1px solid #eef2f7;
        padding: 18px 20px;
    }

    .modal-title {
        font-weight: 900;
        color: #0f172a;
    }

    .modal-body {
        padding: 18px 20px;
    }

    .option-group-card {
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 14px;
        margin-bottom: 14px;
        background: #f8fafc;
    }

    .option-group-title {
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .option-row-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 14px;
        background: #fff;
        margin-bottom: 8px;
        border: 1px solid #eef2f7;
        transition: .2s ease;
    }

        .option-row-item:hover {
            border-color: #bbf7d0;
            background: #f0fdf4;
        }

    .option-price {
        margin-left: auto;
        color: #16a34a;
        font-size: 13px;
        font-weight: 800;
    }

    @@media (max-width: 991px) {
        .menu-layout

    {
        grid-template-columns: 1fr;
    }

    .summary-card {
        position: static;
    }

    }

    @@media (max-width: 767px) {
        .hero-card

    {
        padding: 22px 18px;
        min-height: auto;
    }

    .hero-title {
        font-size: 28px;
    }

    .menu-grid {
        grid-template-columns: 1fr;
    }

    .category-title-text {
        font-size: 20px;
    }

    }
</style>

<div id="app" class="container py-4 py-md-5">
    <div class="menu-page">

        <div class="hero-card" v-if="store">
            <div class="hero-content">
                <div class="hero-badge">
                    <span>🍽️</span>
                    <span>加入這一團</span>
                </div>

                <div class="hero-title">
                    {{ store.storeName || '店家菜單' }}
                </div>

                <div class="hero-sub">
                    想吃什麼就選，別像人生一樣什麼都想要最後什麼都沒點。
                </div>

                <div class="hero-meta">
                    <div class="hero-meta-chip">
                        <span>📍</span>
                        <span>{{ store.storeAddress || '未提供地址' }}</span>
                    </div>
                    <div class="hero-meta-chip">
                        <span>🛒</span>
                        <span>已選 {{ selectedItemCount }} 項</span>
                    </div>
                    <div class="hero-meta-chip">
                        <span>💰</span>
                        <span>目前小計 ${{ totalAmount }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div v-if="categories.length > 0" class="menu-layout">

            <div class="left-column">

                <div class="section-card">
                    <div class="category-nav">
                        <button type="button"
                                class="category-chip"
                                :class="{ active: activeCategoryId === cat.categoryId }"
                                v-for="cat in categories"
                                :key="'nav-' + cat.categoryId"
                                @@click="scrollToCategory(cat.categoryId)">
                            {{ cat.categoryName }}
                        </button>
                    </div>
                </div>

                <div v-for="cat in categories"
                     :key="'section-' + cat.categoryId"
                     class="category-section"
                     :id="'cat-' + cat.categoryId">

                    <div class="category-title">
                        <div class="category-title-text">
                            {{ cat.categoryName }}
                        </div>
                        <div class="category-title-count">
                            {{ cat.items.length }} 項
                        </div>
                    </div>

                    <div class="menu-grid">
                        <div class="menu-item-card"
                             v-for="item in cat.items"
                             :key="item.storeMenuItemPublicId">

                            <div class="menu-media">
                                <img v-if="item.imageUrl"
                                     :src="item.imageUrl"
                                     class="menu-img" />
                                <div v-else class="menu-img-placeholder">
                                    🍱
                                </div>
                            </div>

                            <div class="menu-body">
                                <div class="menu-top">
                                    <div class="menu-name">
                                        {{ item.name }}
                                    </div>

                                    <div class="menu-desc">
                                        {{ item.description || '這道餐點沒有額外說明，但餓的時候看什麼都像美食。' }}
                                    </div>

                                    <div class="menu-price-row">
                                        <div class="menu-price">
                                            ${{ displayItemPrice(item) }}
                                        </div>

                                        <button v-if="item.optionGroups && item.optionGroups.length > 0"
                                                type="button"
                                                class="customize-btn"
                                                @@click="openOptions(item)">
                                            客製化
                                        </button>
                                    </div>

                                    <div class="selected-options">
                                        <template v-if="getSelectedOptions(item).length > 0">
                                            <span class="badge-option"
                                                  v-for="opt in getSelectedOptions(item)"
                                                  :key="item.storeMenuItemPublicId + '-' + opt.optionId">
                                                {{ opt.optionName }}
                                                <span v-if="opt.priceAdjust > 0">
                                                    +{{ opt.priceAdjust }}
                                                </span>
                                            </span>
                                        </template>
                                        <template v-else-if="item.optionGroups && item.optionGroups.length > 0">
                                            <span class="qty-hint">尚未選擇客製化</span>
                                        </template>
                                    </div>
                                </div>

                                <div class="qty-row">
                                    <div class="qty-hint">
                                        調整數量
                                    </div>

                                    <div class="qty-box">
                                        <button type="button"
                                                class="qty-btn"
                                                @@click="decQty(item)">
                                            -
                                        </button>

                                        <input class="qty-input"
                                               type="number"
                                               min="0"
                                               v-model.number="item.qty" />

                                        <button type="button"
                                                class="qty-btn"
                                                @@click="incQty(item)">
                                            +
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </div>

            <div class="right-column">
                <div class="section-card summary-card">

                    <div class="summary-title">
                        你的訂單
                    </div>

                    <div class="summary-sub">
                        確認一下品項、數量與備註，別送出去後才開始懷疑人生。
                    </div>

                    <div class="summary-total-box">
                        <div class="summary-total-label">預估金額</div>
                        <div class="summary-total-amount">${{ totalAmount }}</div>
                    </div>

                    <div class="selected-count">
                        <span>已選品項數</span>
                        <span>{{ selectedItemCount }}</span>
                    </div>

                    <div class="summary-note-label">
                        備註給商家
                    </div>

                    <textarea class="note-textarea"
                              v-model="note"
                              placeholder="例如：小辣、不要香菜、飯少一點、飲料去冰"></textarea>

                    <div class="note-hint">
                        備註會一併送給商家，但最終仍以店家實際可提供內容為準。
                    </div>

                    <div class="summary-divider"></div>

                    <button class="checkout-btn"
                            :disabled="totalAmount <= 0 || submitting"
                            @@click="submitOrder">
                        <span v-if="!submitting">確認選餐並送出</span>
                        <span v-else>
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            送出中...
                        </span>
                    </button>

                    <div class="summary-safe-text">
                        實際金額以店家確認為準，送出前記得再看一次。
                    </div>

                </div>
            </div>

        </div>

        <div v-else class="empty-box">
            這個團目前沒有可選擇的菜單品項。
        </div>

        <div class="modal fade" id="optionsModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">
                            客製化設定 - {{ currentItem ? currentItem.name : '' }}
                        </h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>

                    <div class="modal-body" v-if="currentItem">

                        <div v-if="!currentItem.optionGroups || currentItem.optionGroups.length === 0"
                             class="text-muted">
                            此品項沒有可調整的客製化設定。
                        </div>

                        <div v-else>
                            <div class="mb-3 small text-muted">
                                請選擇需要的客製化選項，加價金額會自動計入總價。
                            </div>

                            <div v-for="(grp, gi) in currentItem.optionGroups"
                                 :key="currentItem.storeMenuItemPublicId + '-group-' + gi"
                                 class="option-group-card">

                                <div class="option-group-title">
                                    {{ grp.groupName || '客製化' }}
                                </div>

                                <label class="option-row-item"
                                       v-for="(opt, oi) in grp.options"
                                       :key="currentItem.storeMenuItemPublicId + '-opt-' + oi">

                                    <input class="form-check-input"
                                           type="checkbox"
                                           v-model="opt.selected" />

                                    <span>{{ opt.optionName }}</span>

                                    <span class="option-price">
                                        <span v-if="opt.priceAdjust > 0">+{{ opt.priceAdjust }} 元</span>
                                        <span v-else>不加價</span>
                                    </span>
                                </label>

                            </div>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-light"
                                data-bs-dismiss="modal">
                            取消
                        </button>
                        <button type="button"
                                class="btn btn-success"
                                data-bs-dismiss="modal">
                            確認
                        </button>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>
    const { createApp } = Vue;

    createApp({

        data() {
            return {
                groupId: '@groupId',
                store: null,
                categories: [],
                submitting: false,
                note: '',
                currentItem: null,
                orderSource: 0,
                takeMode: 1,
                activeCategoryId: null
            };
        },

        computed: {

            totalAmount() {
                return this.categories.reduce((sum, cat) => {
                    return sum + cat.items.reduce((s, x) => {

                        if (!x.qty || x.qty <= 0) {
                            return s;
                        }

                        var extra = 0;

                        if (x.optionGroups) {
                            x.optionGroups.forEach(function (g) {
                                g.options.forEach(function (o) {
                                    if (o.selected) {
                                        extra += o.priceAdjust || 0;
                                    }
                                });
                            });
                        }

                        return s + (x.price + extra) * x.qty;

                    }, 0);
                }, 0);
            },

            selectedItemCount() {
                return this.categories.reduce((sum, cat) => {
                    return sum + cat.items.reduce((s, x) => {
                        return s + (x.qty && x.qty > 0 ? x.qty : 0);
                    }, 0);
                }, 0);
            }

        },

        methods: {

            loadMenu() {
                axios.get('/api/groups/menu/' + this.groupId)
                    .then(res => {

                        const data = res.data || {};

                        this.store = {
                            storeId: data.storeId,
                            storeName: data.storeName,
                            storeAddress: data.storeAddress
                        };

                        this.categories = (data.categories || []).map(c => ({
                            categoryId: c.categoryId,
                            categoryName: c.categoryName,
                            items: (c.items || []).map(x => ({
                                storeMenuItemPublicId: x.storeMenuItemPublicId,
                                name: x.name,
                                price: x.price,
                                description: x.description,
                                imageUrl: x.imageUrl,
                                qty: 0,
                                optionGroups: (x.optionGroups || []).map(g => ({
                                    groupName: g.groupName,
                                    options: (g.options || []).map(o => ({
                                        optionId: o.optionId,
                                        optionName: o.optionName,
                                        priceAdjust: o.priceAdjust || 0,
                                        selected: false
                                    }))
                                }))
                            }))
                        }));

                        if (this.categories.length > 0) {
                            this.activeCategoryId = this.categories[0].categoryId;
                        }

                    })
                    .catch(() => {
                        alert("菜單載入失敗");
                    });
            },

            incQty(item) {
                if (!item.qty) item.qty = 0;
                item.qty++;
            },

            decQty(item) {
                if (!item.qty) item.qty = 0;
                if (item.qty > 0) item.qty--;
            },

            openOptions(item) {
                this.currentItem = item;

                var modalEl = document.getElementById('optionsModal');
                if (!modalEl || typeof bootstrap === 'undefined') {
                    return;
                }

                var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                modal.show();
            },

            submitOrder() {

                if (this.submitting) return;

                const selected = [];

                this.categories.forEach(cat => {
                    cat.items.forEach(x => {

                        if (x.qty && x.qty > 0) {

                            const options = [];

                            if (x.optionGroups) {
                                x.optionGroups.forEach(g => {
                                    g.options.forEach(o => {
                                        if (o.selected) {
                                            options.push({
                                                optionId: o.optionId,
                                                optionName: o.optionName,
                                                priceAdjust: o.priceAdjust
                                            });
                                        }
                                    });
                                });
                            }

                            selected.push({
                                storeMenuItemPublicId: x.storeMenuItemPublicId,
                                quantity: x.qty,
                                options: options
                            });
                        }

                    });
                });

                if (selected.length === 0) {
                    alert("請至少選一項品項");
                    return;
                }

                this.submitting = true;

                axios.post('/api/orders/create', {
                    groupOrderPublicId: this.groupId,
                    items: selected,
                    note: this.note || '',
                    source: this.orderSource,
                    takeMode: this.takeMode
                })
                .then(() => {
                    window.location.href = '/Group/GroupDetail/' + this.groupId;
                })
                .catch(() => {
                    alert("下單失敗");
                })
                .finally(() => {
                    this.submitting = false;
                });

            },

            displayItemPrice(item) {

                var base = item.price || 0;
                var extra = 0;

                if (item.optionGroups) {
                    item.optionGroups.forEach(function (g) {
                        g.options.forEach(function (o) {
                            if (o.selected) {
                                extra += o.priceAdjust || 0;
                            }
                        });
                    });
                }

                return base + extra;
            },

            getSelectedOptions(item) {

                var result = [];

                if (!item.optionGroups) {
                    return result;
                }

                item.optionGroups.forEach(function (g) {
                    g.options.forEach(function (o) {
                        if (o.selected) {
                            result.push(o);
                        }
                    });
                });

                return result;
            },

            scrollToCategory(categoryId) {
                this.activeCategoryId = categoryId;

                var el = document.getElementById('cat-' + categoryId);
                if (el) {
                    el.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            }

        },

        mounted() {

            const params = new URLSearchParams(window.location.search);
            const src = params.get("source");

            if (src === 'manual') {
                this.orderSource = 1;
            } else {
                this.orderSource = 0;
            }

            this.loadMenu();
        }

    }).mount('#app');
</script>